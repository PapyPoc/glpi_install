# Sequence principale d'installation et de mise à jour de GLPI
function run_sequence() {
    debug_start
    trap 'on_error' ERR
    local mode="$1"
    declare -A tasks
    local task_order=()
    # --- Sélection du mode ---
    case "${mode}" in
        install)
            tasks=(
                ["$(gt "Mise à jour de la distribution")"]="update_distro"
                ["$(gt "Installation des paquets")"]="install_packages"
                ["$(gt "Informations réseau")"]="network_info"
                ["$(gt "Configuration de MariaDB")"]="mariadb_configure"
                ["$(gt "Téléchargement et extraction de GLPI") ${VERSION_SELECT}"]="download_untar_glpi"
                ["$(gt "Configuration de GLPI") ${VERSION_SELECT}"]="setup_glpi"
                ["$(gt "Mise à jour de l'utilisateur GLPI")"]="maj_user_glpi"
                ["$(gt "Écriture des informations d'identification")"]="write_credentials"
            )
            task_order=(
                "$(gt "Mise à jour de la distribution")" "$(gt "Installation des paquets")" "$(gt "Informations réseau")" "$(gt "Configuration de MariaDB")" "$(gt "Téléchargement et extraction de GLPI") ${VERSION_SELECT}" "$(gt "Configuration de GLPI") ${VERSION_SELECT}" "$(gt "Mise à jour de l'utilisateur GLPI")" "$(gt "Écriture des informations d'identification")"
            )
            ;;
        update)
            tasks=(
                ["$(gt "Maintenance 1")"]="maintenance 1"
                ["$(gt "Mise à jour de la distribution")"]="update_distro"
                ["$(gt "Sauvegarde de GLPI")"]="backup_glpi"
                ["$(gt "Suppression de l'ancienne version de GLPI")"]="remove_old_glpi"
                ["$(gt "Téléchargement et extraction de GLPI") ${VERSION_SELECT}"]="download_untar_glpi"
                ["$(gt "Mise à jour de GLPI")"]="update_glpi"
                ["$(gt "Maintenance 0")"]="maintenance 0"
            )
            task_order=(
                "$(gt "Maintenance 1")" "$(gt "Mise à jour de la distribution")" "$(gt "Sauvegarde de GLPI")" "$(gt "Suppression de l'ancienne version de GLPI")" "$(gt "Téléchargement et extraction de GLPI") ${VERSION_SELECT}" "$(gt "Mise à jour de GLPI")" "$(gt "Maintenance 0")"
            )
            ;;
        backup)
            tasks=(
                ["$(gt "Sauvegarde complète de GLPI")"]="backup_glpi"
            )
            task_order=(
                "$(gt "Sauvegarde complète de GLPI")"
            )
            ;;
        restore)
            tasks=(
                ["$(gt "Restauration complète de GLPI")"]="restore_glpi_all"
            )
            task_order=(
                "$(gt "Restauration complète de GLPI")"
            )
            ;;
        migrate)
            tasks=(
                ["$(gt "Migration complète de GLPI")"]="migrate_glpi_all"
            )
            task_order=(
                "$(gt "Migration complète de GLPI")"
            )
            ;;
        *)
            warn "$(gt "Mode inconnu : ${mode} — modes valides : install | update | backup | restore | migrate")"
            return 1
            ;;
    esac
    # --- Initialisation ---
    local total_tasks=${#task_order[@]}
    local task_index=0
    (
    for task_key in "${task_order[@]}"; do
        ((task_index++))
        local progress=$((task_index * 100 / total_tasks))
        local task_cmd="${tasks[${task_key}]}"
        # --- Affichage dans la jauge ---
        echo "${progress}"
        echo "XXX"
        echo "${task_index}/${total_tasks} - ${task_key} ⏳"
        echo "XXX"
        debug "$(date '+%F %T') [$$][DEBUG] $(gt "Début de la séquence :") ${mode} - '${task_key}' → ${task_cmd}"
        # --- Exécution de la tâche ---
        if run_task "${task_key}" "${task_cmd}" "${task_index}" "${total_tasks}" >/dev/null 2>&1; then
            echo "${progress}"
            echo "XXX"
            echo "${task_index}/${total_tasks} - ${task_key} ✔️"
            echo "XXX"
            debug "$(date '+%F %T') [$$][DEBUG] ✔️ $(gt "Fin de la séquence :") ${mode} - '${task_key}'."
            sleep 0.5  # légère pause visuelle
        else
            echo "100"
            echo "XXX"
            echo "${task_index}/${total_tasks} - ${task_key} ❌"
            echo "XXX"
            debug "$(date '+%F %T') [$$][DEBUG] ❌ $(gt "Fin de la séquence :") ${mode} - '${task_key}'."
            sleep 3
            exit 1  # << plus sûr que return dans un sous-shell
        fi
    done
        ) | dialog --clear \
           --backtitle "$(gt "Installation de GLPI")" \
           --title "$(gt "Progression")" \
           --gauge "" 8 120 >/dev/tty 2>&1
    # --- Vérification du sous-shell ---
    if [[ ${PIPESTATUS[0]} -ne 0 ]]; then
        warn "$(gt "Une tâche a échoué pendant l'exécution du mode :") (${mode})"
        return 1
    fi
    info "$(gt "Toutes les tâches du mode") (${mode}) $(gt "ont été exécutées avec succès.")"
    debug_end
}
# Exécute une tâche individuelle
function run_task() {
    trap 'on_error' ERR
    local task_key="$1" task_cmd="$2" index="$3" total="$4"
    debug_start
    debug "$(gt "Commande") ${task_cmd} ${task_key}/${total}"
    # Exécution isolée
    local output exit_code
    output=$(eval "${task_cmd}" 2>&1)
    exit_code=$?
    if (( exit_code == 0 )); then
        debug "${task_key} - $(gt "terminée avec succès") - '${task_cmd}'"
        [[ -n "${output}" ]] && debug "↳ ${output}"
    else
        warn "${task_key} - $(gt "échouée") - '${task_cmd}' -> (exit=${exit_code})"
        [[ -n "${output}" ]] && warn "↳ ${output}"
        return ${exit_code}
    fi
    debug_end
}
# Mise à jour de la distribution
function update_distro(){
    debug_start
    if [[ "${DISTRO_ID}" =~ ^(debian|ubuntu)$ ]]; then
           info "$(gt "Mise à jour de la distribution") ${DISTRO_ID} ${VERSION_ID}"
           timedatectl set-ntp true # Synchronise l'heure
           sleep 5
           apt-get update && apt-get upgrade -y >> "${UPDATEFILE}" 2>> "${ERRORFILE}"
    elif [[ "${DISTRO_ID}" =~ ^(almalinux|centos|rocky|rhel)$ ]]; then
           info "$(gt "Mise à jour de la distribution") ${DISTRO_ID} ${VERSION_ID}"
           chronyc makestep # Synchronise l'heure
           sleep 5
           yum update -y && yum upgrade -y >> "${UPDATEFILE}" 2>> "${ERRORFILE}"
    else
        warn "$(gt "Mise à jour de la distribution non prise en charge")"
        exit 1
    fi
    debug_end
}
# Adresse IP de la machine
function network_info() {
    debug_start    
    # Détection de l’interface principale (hors loopback et interfaces virtuelles)
    INTERFACE=$(ip route get 1.1.1.1 2>/dev/null | awk '/dev/ {print $5; exit}')
    if [[ -z "${INTERFACE}" ]]; then
        INTERFACE=$(ip -o link show | awk -F': ' '!/lo|docker|vir|veth/ {print $2; exit}')
    fi
    # Récupération de l’adresse IP associée
    IPADRESS=$(ip -4 addr show "${INTERFACE}" 2>/dev/null | awk '/inet / {print $2}' | cut -d'/' -f1 | head -n1)
    # Vérification et export
    if [[ -n "${IPADRESS}" ]]; then
        # Adresse IP valide trouvée
        info "$(gt "Interface réseau détectée :") ${INTERFACE}, $(gt "Adresse IP détectée :") ${IPADRESS}"
        export IPADRESS
    else
        # Aucune adresse IP valide trouvée
        warn "$(gt "Impossible de déterminer l’adresse IP du serveur via l’interface réseau principale.")"
        IPADRESS="127.0.0.1"
        export IPADRESS
    fi
    debug_end
}
# Installation des éléments nécessaire
function install_packages(){
    debug_start    
    info "$(gt "Début de l'installation des paquets nécessaires...")"
    source_os_release
    if [[ "${DISTRO_ID:-}" =~ ^(debian|ubuntu)$ ]]; then
        export DEBIAN_FRONTEND=noninteractive
        # update cache first
        if command -v sudo apt-get update | sudo tee -a "${UPDATEFILE}" 2> >(sudo tee -a "${ERRORFILE}" >&2); then
            debug "apt-get upgrade -y"
            if ! sudo apt-get upgrade -y | sudo tee -a "${UPDATEFILE}" 2> >(sudo tee -a "${ERRORFILE}" >&2); then
                warn "$(gt "Échec de la mise à jour des paquets.")"
            fi
        fi
        info "$(gt "Installation des extensions PHP requises.")"
        if ! sudo apt-get install -y php-{bcmath,mysql,mbstring,curl,gd,xml,intl,ldap,apcu,opcache,xmlrpc,zip,bz2} | sudo tee -a "${UPDATEFILE}" 2> >(sudo tee -a "${ERRORFILE}" >&2); then
            error "$(gt "Échec de l'installation des extensions PHP requises.")"
            return 1
        else
            info "$(gt "Installation des extensions PHP requises terminée avec succès.")"
        fi
        info "$(gt "Installation des services requis.")"
        if ! sudo apt-get install -y wget tar apache2 apache2-bin mariadb-server mariadb-client perl php | sudo tee -a "${UPDATEFILE}" 2> >(sudo tee -a "${ERRORFILE}" >&2); then
            error "$(gt "Échec de l'installation des services requis.")"
            return 1
        else
            info "$(gt "Installation des services requis terminée avec succès.")"
        fi
        manage_service "mariadb" "MariaDB" || return 1
        manage_service "apache2" "Apache2" || return 1
    fi
    if [[ "${DISTRO_ID:-}" =~ ^(almalinux|centos|rocky|rhel|fedora)$ ]]; then
        sudo dnf makecache --refresh
        if ! command -v dnf >/dev/null 2>&1; then
            error "$(gt "dnf introuvable, impossible d'installer les paquets sur la branche RHEL-like.")" | tee -a "${ERRORFILE}"
            return 1
        fi
        if sudo dnf makecache --refresh | sudo tee -a "${DEBUGFILE}" 2> >(sudo tee -a "${ERRORFILE}" >&2); then
            info "$(gt "Cache DNF rafraîchi avec succès.")"
        else
            error "$(gt "Échec du rafraîchissement du cache DNF.")"
        fi
        if sudo dnf install -y https://dl.fedoraproject.org/pub/epel/epel-release-latest-9.noarch.rpm \
            | sudo tee -a "${DEBUGFILE}" \
            2> >(sudo tee -a "${ERRORFILE}" >&2); then
            info "$(gt "Installation du dépôt EPEL terminée avec succès.")"
        else
            error "$(gt "Échec de l'installation du dépôt EPEL.")"
            return 1
        fi
        if sudo dnf module reset -y php nginx mariadb composer \
            | sudo tee -a "${DEBUGFILE}" \
            2> >(sudo tee -a "${ERRORFILE}" >&2); then
            info "$(gt "Réinitialisation des modules DNF terminée avec succès.")"
        else
            error "$(gt "Échec de la réinitialisation des modules DNF.")"
            return 1
        fi
        if sudo dnf module install -y php:8.4 \
            | sudo tee -a "${DEBUGFILE}" \
            2> >(sudo tee -a "${ERRORFILE}" >&2); then
            info "$(gt "Installation du module PHP terminée avec succès.")"
        else
            error "$(gt "Échec de l'installation du module PHP.")"
            return 1
        fi
        if sudo dnf module install -y nginx:1.24 \
            | sudo tee -a "${DEBUGFILE}" \
            2> >(sudo tee -a "${ERRORFILE}" >&2); then
            info "$(gt "Installation du module NGINX terminée avec succès.")"
        else
            error "$(gt "Échec de l'installation du module NGINX.")"
            return 1
        fi
        if sudo dnf module install -y mariadb:10.11 \
                | sudo tee -a "${DEBUGFILE}" \
                2> >(sudo tee -a "${ERRORFILE}" >&2); then
            info "$(gt "Installation du module MariaDB terminée avec succès.")"
        else
            error "$(gt "Échec de l'installation du module MariaDB.")"
            return 1
        fi
        if sudo dnf install -y dnf-automatic \
                | sudo tee -a "${DEBUGFILE}" \
                2> >(sudo tee -a "${ERRORFILE}" >&2); then
            info "$(gt "Installation de dnf-automatic terminée avec succès.")"
        else
            error "$(gt "Échec de l'installation de dnf-automatic.")"
            return 1
        fi
        sed -i 's/^\s*;\?\s*\(apply_updates\s*=\s*\).*/\1yes/' /etc/dnf/automatic.conf
        sed -i 's/^\s*;\?\s*\(reboot\s*=\s*\).*/\1when-needed/' /etc/dnf/automatic.conf
        sed -i 's/^\s*;\?\s*\(upgrade_type\s*=\s*\).*/\1security/' /etc/dnf/automatic.conf
        if sudo mkdir -p /etc/systemd/system/dnf-automatic.timer.d | sudo tee -a "${DEBUGFILE}" 2>>"${ERRORFILE}"; then
