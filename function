    # Vérifier si le nom est déjà utilisé dans les fichiers de sauvegarde
    local found_file
    found_file="$(find "${INVOKING_HOME}/saved_credentials" -type f -name "${FICHIER_MSG}_${clean_name}*" -print -quit 2>/dev/null)"
