        fi
        if dnf install -y php-{bcmath,mysql,mbstring,curl,gd,xml,intl,ldap,apcu,opcache,xmlrpc,zip,bz2}; then
            info "$(gt "Installation des extensions PHP terminée avec succès.")"
        else
