set -Eeuo pipefail
# Ne pas continuer si le script est exécuté directement
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    echo -e "Ce fichier doit être sourcé, pas exécuté.\n" >&2
    echo -e "This file must be sourced, not executed.\n" >&2
    exit 1
fi
# Affichage d'erreur en rouge
function error(){
    local msg="$1"
    local expanded
    if command -v envsubst >/dev/null 2>&1; then
        expanded=$( ( set +u; printf '%s' "$msg" | envsubst ) )
    else
        expanded=$( ( set +u; eval "printf '%s' \"$msg\"" ) )
    fi
    echo -e "❗ ${ROUGE}${expanded}${NC}" # Couleur rouge # Affichage à l'écran désactivé
    printf '%s\n' "${expanded}" | tee -a "${ERRORFILE}" >/dev/null
}
# Affichage d'alerte en orange
function warn(){
    local msg="$1"
    local expanded
    if command -v envsubst >/dev/null 2>&1; then
        expanded=$( ( set +u; printf '%s' "$msg" | envsubst ) )
    else
        expanded=$( ( set +u; eval "printf '%s' \"$msg\"" ) )
    fi
    echo -e "${ORANGE}${expanded}${NC}" # Couleur orange
    printf '%s\n' "${expanded}" | tee -a "${ERRORFILE}" >/dev/null # Affichage dans le fichier d'alerte
}
# Affichage d'information en bleu
function info(){
    local msg="$1"
    local expanded
    if command -v envsubst >/dev/null 2>&1; then
        expanded=$( ( set +u; printf '%s' "$msg" | envsubst ) )
    else
        expanded=$( ( set +u; eval "printf '%s' \"$msg\"" ) )
    fi
    echo -e "ℹ️ ${CYAN}${expanded}${NC}" # Couleur cyan
    printf '%s\n' "${expanded}" | tee -a "${INFOFILE}" >/dev/null # Affichage dans le fichier d'info
}
function debug() {
    local message="$*"
    mkdir -p "$(dirname -- "${DEBUGFILE}")"
    touch "${DEBUGFILE}"
    echo "${message}" >> "${DEBUGFILE}"
}
# Affichage debug en normal
function debug_start(){
    local msg
    msg="$(date '+%F %T') [$$][DEBUG: ${FUNCNAME[0]:-main}] Depuis ${FUNCNAME[1]:-main}"
    local expanded
    if command -v envsubst >/dev/null 2>&1; then
        expanded=$( ( set +u; printf '%s' "$msg" | envsubst ) )
    else
        expanded=$( ( set +u; eval "printf '%s' \"$msg\"" ) )
    fi
    #echo -e "🐞 ${NC}${expanded}${NC}" # Couleur normale
    printf '%s\n' "🐞 ${expanded}" | tee -a "${DEBUGFILE}" >/dev/null # Affichage dans le fichier de debug
}
function debug_end(){
    local msg
    msg="$(date '+%F %T') [$$][DEBUG: Fin de ${FUNCNAME[0]:-main}] Appeler par ${FUNCNAME[1]:-main}"
    local expanded
    if command -v envsubst >/dev/null 2>&1; then
        expanded=$( ( set +u; printf '%s' "$msg" | envsubst ) )
    else
        expanded=$( ( set +u; eval "printf '%s' \"$msg\"" ) )
    fi
    #echo -e "🐞 ${NC}${expanded}${NC}" # Couleur normale
    printf '%s\n' "🐞 ${expanded}" | tee -a "${DEBUGFILE}" >/dev/null # Affichage dans le fichier de debug
}
function gt(){
    if command -v gettext >/dev/null 2>&1; then
        gettext "$@" || echo "$1 - Missing translation"  # Fallback si traduction absente
    else
        printf '%s\n' "$1"
    fi
}
# Gestion des erreurs avec trap
function on_error() {
    local rc=$?                               # Code de retour de la dernière commande
    local cmd="${BASH_COMMAND}"               # Commande qui a échoué
    local line="${BASH_LINENO[0]}"            # Ligne d’erreur
    local message=""
    local err_dial=""
    message+="$(gt "Erreur détectée : '${cmd}' (code=${rc}) à la ligne ${line}")\n"
    message+="$(gt "Pile d'appels :")\n"
    # Boucle sur la pile d’appels (stack trace)
    for (( i=${#FUNCNAME[@]}-1; i>=1; i-- )); do
        # i=0 correspond à on_error elle-même → on la saute
        message+="$(gt "  ↳ ")${FUNCNAME[$i]}() $(gt "depuis") ${BASH_SOURCE[$i]}:${BASH_LINENO[$((i-1))]}\n"
    done
    message+="──────────────────────────────"
    # Affichage dans dialog (protéger les retours ligne)
    err_dial+=""
    err_dial=$(dialog --clear --backtitle "$(gt "Erreur critique")" --title "$(gt "Erreur détectée")" \
           --msgbox "$(echo -e "$message")" 20 100 2>&1 >/dev/tty)
    # Log du message complet dans les fichiers d’erreur
    error "$(echo -e "$message")"
    exit "${rc}"
}
source_os_release() {
    if [ -r /etc/os-release ]; then
        # shellcheck disable=SC1091
        source /etc/os-release
        DISTRO_ID="${ID,,}"
        DISTRO_NAME="${NAME:-${ID}}"
        DISTRO_VERSION="${VERSION_ID:-}"
        debug "$(gt "Distribution détectée :") ${DISTRO_NAME} ${DISTRO_VERSION}"
        export DISTRO_ID DISTRO_NAME DISTRO_VERSION
        return 0
    fi
    warn "$(gt "Fichier /etc/os-release introuvable ou illisible.")"
    return 1
}
# Détéction du code pays pour les paramètres régionaux et le fuseau horaire
detect_country_code() {
    local country="${COUNTRY_CODE:-}"
    # Si COUNTRY_CODE n'est pas fourni, tentative via IP publique
    if [ -z "${country}" ] && command -v curl >/dev/null 2>&1; then
        country="$(curl -fsSL --max-time 5 https://ipapi.co/country_code/ 2>/dev/null || true)"
    fi
    country="${country^^}"
    case "${country}" in
        [A-Z][A-Z])
            printf '%s\n' "${country}"
            ;;
        *)
            printf '%s\n' "FR"
            ;;
    esac
}
# Détection du code pays et configuration des paramètres régionaux et du fuseau horaire
set_country_defaults() {
    local country="$1"
    case "${country}" in
        FR)
            DEFAULT_LOCALE="fr_FR.UTF-8"
            DEFAULT_LANGUAGE="fr_FR"
            TIMEZONES="Europe/Paris"
            ;;
        BE)
            DEFAULT_LOCALE="fr_BE.UTF-8"
            DEFAULT_LANGUAGE="fr_BE"
            TIMEZONES="Europe/Brussels"
            ;;
        CH)
            DEFAULT_LOCALE="fr_CH.UTF-8"
            DEFAULT_LANGUAGE="fr_CH"
            TIMEZONES="Europe/Zurich"
            ;;
        LU)
            DEFAULT_LOCALE="fr_LU.UTF-8"
            DEFAULT_LANGUAGE="fr_LU"
            TIMEZONES="Europe/Luxembourg"
            ;;
        GB|UK)
            DEFAULT_LOCALE="en_GB.UTF-8"
            DEFAULT_LANGUAGE="en_GB"
            TIMEZONES="Europe/London"
            ;;
        US)
            DEFAULT_LOCALE="en_US.UTF-8"
            DEFAULT_LANGUAGE="en_US"
            TIMEZONES="America/New_York"
            ;;
        DE)
            DEFAULT_LOCALE="de_DE.UTF-8"
            DEFAULT_LANGUAGE="de_DE"
            TIMEZONES="Europe/Berlin"
            ;;
        ES)
            DEFAULT_LOCALE="es_ES.UTF-8"
            DEFAULT_LANGUAGE="es_ES"
            TIMEZONES="Europe/Madrid"
            ;;
        IT)
            DEFAULT_LOCALE="it_IT.UTF-8"
            DEFAULT_LANGUAGE="it_IT"
            TIMEZONES="Europe/Rome"
            ;;
        *)
            DEFAULT_LOCALE="fr_FR.UTF-8"
            DEFAULT_LANGUAGE="fr_FR"
            TIMEZONES="Europe/Paris"
            ;;
    esac
}
# Configuration de la locale et du fuseau horaire en fonction du pays détecté
configure_locale_timezone_by_country() {
    local country
    country="$(detect_country_code)"
    set_country_defaults "${country}"
    info "$(gt "Pays détecté :") ${country}"
    info "$(gt "Locale sélectionnée :") ${DEFAULT_LOCALE}"
    info "$(gt "Langue sélectionnée :") ${DEFAULT_LANGUAGE}"
    info "$(gt "Fuseau horaire sélectionné :") ${TIMEZONES}"
    if command -v apt-get >/dev/null 2>&1; then
        export DEBIAN_FRONTEND=noninteractive
        apt-get update -qq >>"${UPDATEFILE}" 2>>"${ERRORFILE}"
        apt-get install -y -qq locales tzdata curl >>"${UPDATEFILE}" 2>>"${ERRORFILE}"
    fi
    # Génération locale
    if [ -f /etc/locale.gen ]; then
        if grep -Fxq "# ${DEFAULT_LOCALE} UTF-8" /etc/locale.gen; then
            sed -i "s/^# ${DEFAULT_LOCALE} UTF-8/${DEFAULT_LOCALE} UTF-8/" /etc/locale.gen
        elif ! grep -Fxq "${DEFAULT_LOCALE} UTF-8" /etc/locale.gen; then
            echo "${DEFAULT_LOCALE} UTF-8" >> /etc/locale.gen
        fi

        locale-gen "${DEFAULT_LOCALE}" >>"${DEBUGFILE}" 2>>"${ERRORFILE}" || {
            warn "$(gt "Impossible de générer la locale :") ${DEFAULT_LOCALE}"
            return 1
        }
    fi
    # Configuration persistante locale
    cat > /etc/default/locale <<EOF
LANG=${DEFAULT_LOCALE}
LANGUAGE=${DEFAULT_LANGUAGE}
EOF
    export LANG="${DEFAULT_LOCALE}"
    export LANGUAGE="${DEFAULT_LANGUAGE}"
    unset LC_ALL
    # Configuration timezone
    if [ -f "/usr/share/zoneinfo/${TIMEZONES}" ]; then
        ln -snf "/usr/share/zoneinfo/${TIMEZONES}" /etc/localtime
        echo "${TIMEZONES}" > /etc/timezone

        dpkg-reconfigure -f noninteractive tzdata >>"${DEBUGFILE}" 2>>"${ERRORFILE}" || true
    else
        warn "$(gt "Fuseau horaire introuvable :") ${TIMEZONES}"
        return 1
    fi
    info "$(gt "Configuration langue/timezone terminée.")"
}
# Vérifie si la version est compatible
function compatible() {
    debug_start
    local version="$1"
    local -n versions_array="$2"
    [[ ${versions_array[*]} =~ ${version} ]]
    debug_end
}
# Vérifie si la distribution est prise en compte pour l'installation de GLPI
function check_distro(){
    debug_start
    # Vérifie si le fichier os-release existe
    source_os_release
    # Vérifie si la distribution est basée sur Debian, Ubuntu, Alma Linux, Centos ou Rocky Linux
    if [[ "${DISTRO_ID}" =~ ^(debian|ubuntu|almalinux|centos|rocky|rhel)$ ]]; then
        if [[ "$DISTRO_ID" == "debian" || "$DISTRO_ID" == "ubuntu" ]]; then
            WEB_USER="www-data"
        else
            WEB_USER="nginx"
        fi
        if compatible "${VERSION_ID}" DEBIAN_VERSIONS || compatible "$VERSION_ID" UBUNTU_VERSIONS || compatible "$VERSION_ID" ALMA_VERSIONS || compatible "$VERSION_ID" CENTOS_VERSIONS || compatible "$VERSION_ID" ROCKY_VERSIONS || compatible "$VERSION_ID" REDHAT_VERSIONS; then
            info "$(gt "Distribution prise en charge")"
        else
            warn "$(gt "Distribution non prise en charge")"
            warn "$(gt "Souhaitez-vous forcer l'installation sur cette distribution ?")"
            if [ -t 0 ]; then
                info "$(gt "Forcer l'installation ? (O/N)")"
                read -r RESPONSE
                case $RESPONSE in
                    O|o|Y|y)
                        info "$(gt "Poursuite de l'installation...")"
                        ;;
                    N|n)
                        info "$(gt "Sortie...")"
                        return 1
                        ;;
                    *)
                        warn "$(gt "Réponse invalide")"
                        return 1
                        ;;
                esac
            else
                warn "$(gt "Abandon de l'installation en mode forcé.")"
                return 1
            fi
        fi
        export VERSION_ID DISTRO_ID WEB_USER
    else
        warn "$(gt "Impossible de déterminer la distribution")"
        return 1
    fi
    export VERSION_ID DISTRO_ID WEB_USER
    debug_end
}
# Recherche si GLPI est déjà installé
function check_glpi_installed(){
    debug_start    
    FIND_REP_GLPI=$?
    glpi_dirs=()
    # Parcours des répertoires standards à explorer
    for path in ${PATHS_TO_CHECK}; do
        # Recherche des dossiers contenant "glpi" jusqu’à 3 niveaux de profondeur
        FOUND=$(find "${path}" -maxdepth 3 -type d -name "*glpi*" 2>/dev/null)
        # Si un ou plusieurs répertoires sont trouvés, on les ajoute au tableau
        if [[ -n "$FOUND" ]]; then
            # On lit chaque ligne de la sortie de find et on l’ajoute au tableau
            while IFS= read -r dir; do
                glpi_dirs+=("$dir")
            done <<< "$FOUND"
        fi
    done
    #echo "Répertoires GLPI trouvés : ${glpi_dirs[*]}"
    export glpi_dirs FIND_REP_GLPI
    debug_end
}
# Recherche si des sauvegardes existent
function check_backups_existed(){
    debug_start    
    BACKUP_FOUND="no"
    # Vérifie si le répertoire de sauvegarde existe
    if [[ -d "${REP_BACKUP}" ]]; then
        # Recherche des fichiers de sauvegarde dans le répertoire
        shopt -s nullglob
        backup_files=("${REP_BACKUP}"/*.tar.gz "${REP_BACKUP}"/*.zip)
        shopt -u nullglob
        if [[ ${#backup_files[@]} -gt 0 ]]; then
            BACKUP_FOUND="yes"
        fi
    fi
    export BACKUP_FOUND
    debug_end
}
# Vérifie l'utilisateur web pour le répertoire GLPI
function check_install_user(){
    debug_start
    info "$(gt "Vérification de l'utilisateur web pour le répertoire :") ${REP_GLPI}"
    REP_GLPI="${1:-/var/www/html/glpi}"
    if ! WEB_USER=$(stat -c '%U' "${REP_GLPI}") >/dev/null 2>&1; then
        debug "$(gt "Impossible de déterminer l'utilisateur web pour le répertoire :") ${REP_GLPI}."
        return 1
    fi
    debug "$(gt "Utilisateur du service web trouvé :") ${WEB_USER}"
    export WEB_USER REP_GLPI
    debug_end
}
# Choix entre installation ou mise à jour
function selection_menu(){
    debug_start
    # Demander à l'utilisateur s'il souhaite installer ou mettre à jour GLPI
    SELECTED_MENU=$(dialog \
        --backtitle "$(gt "Utilitaire de GLPI")" \
        --title "$(gt "Options pour GLPI")" \
        --radiolist "$(gt "Choisissez une option :")" 15 50 3 \
        1 "$(gt "Installation de GLPI")" ON \
        2 "$(gt "Mise à jour de GLPI")" OFF \
        3 "$(gt "Sauvegarde complète de GLPI")" OFF \
        4 "$(gt "Restauration de GLPI")" OFF \
        5 "$(gt "Migration de GLPI")" OFF \
        "" "--------------------------------" OFF \
        7 "$(gt "Sortir")" OFF 2>&1 >/dev/tty)
    rc=$?
    export SELECTED_MENU
    if [[ $rc -ne 0 ]]; then
        error "$(gt "Sélection annulée par l'utilisateur.")"
        dialog --clear --title "$(gt "Annulation")" --msgbox "$(gt "Sélection annulée par l'utilisateur.")" 7 50
        return 1
    fi
    if [[ $rc == 7 ]]; then
        info "$(gt "Sortie demandée par l'utilisateur.")"
        return 100
    fi
    prompt_install_options
    debug_end
}
function get_installed_glpi_version(){
    local rep_glpi="$1"
    if check_install_user "${rep_glpi}"; then
        sudo -u "${WEB_USER}" php "${rep_glpi}/bin/console" --no-ansi --version 2>/dev/null | awk '{print $3}' || true
    fi
}
function get_stable_glpi_tags(){
    curl -fsSL "${API_URL}" \
        | jq -r '.[].name' \
        | grep -E '^[0-9]+\.[0-9]+\.[0-9]+$' \
        | grep -v -E '(rc|beta|alpha)' \
        | sort -Vr \
        | uniq \
        | head -n 16
}
function get_newer_glpi_tags(){
    local installed_version="$1"
    local tag
    while IFS= read -r tag; do
        [[ "$tag" == "$installed_version" ]] && break
        printf '%s\n' "$tag"
    done < <(get_stable_glpi_tags)
}
function build_version_choices(){
    local first="ON"
    local tag
    for tag in "$@"; do
        printf '%s\nGLPI %s\n%s\n' "$tag" "$tag" "$first"
        first="OFF"
    done
}
function select_glpi_update_version(){
    dialog \
        --backtitle "$(gt "Mise à jour de GLPI")" \
        --title "$(gt "Sélection de la version")" \
        --radiolist "$(gt "Veuillez sélectionner la version de GLPI à installer :")" 23 50 8 \
        "$@" 3>&1 1>/dev/tty 2>&3
}
function trim_dialog_value(){
            local value="$1"
            value="${value#"${value%%[![:space:]]*}"}"
            printf '%s' "${value%"${value##*[![:space:]]}"}"
}
function sanitize_path_value(){
    local value
    value="$(trim_dialog_value "$1")"
    printf '%s' "${value//[^A-Za-z0-9_\/.-]/_}"
}
function sanitize_name_value(){
    local value
    value="$(trim_dialog_value "$1")"
    printf '%s' "${value//[^A-Za-z0-9_]/_}"
}

#  Demander à l'utilisateur de choisir le répertoire d'installation,
# la version de GLPI à installer ou de lancer une installation complète via dialog.
function prompt_install_options(){
    debug_start    
    if [[ "${SELECTED_MENU}" == 1 ]]; then # Installation de GLPI
        info "$(gt "Options d'installation de GLPI")"
        tags=""
        # Récupère les tags au format X.Y.Z
        tags=$(curl -s "${API_URL}" | jq -r '.[].name' | grep -E '^[0-9]+\.[0-9]+\.[0-9]+$' | grep -v -E '(rc|beta|alpha)' | sort -Vr | uniq | head -n 16)
        args=() first=ON number=1
        while IFS= read -r tag; do
            args+=("${tag}" "" "${first}")
            first=OFF
        done <<< "${tags}"
        VERSION_SELECT=$(dialog --clear --backtitle "$(gt "Installation de GLPI")" --title "$(gt "Choix pour l'installation de GLPI")" \
        --radiolist "$(gt "Choisissez la version ?")" 23 50 8 "${args[@]}" 3>&1 1>/dev/tty 2>&3)
        rc=$?
        if [ "${rc}" -ne 0 ]; then
            warn "$(gt "Arrêt de l'installation par l'utilisateur.")"
            return 1
        fi
        # Formulaire des options d'installation
        local form="" WIDTH=0
        local label_rep label_db_host label_db_name label_db_user
        label_rep="$(gt "Répertoire d'installation")"
        label_db_host="$(gt "Hôte de la Base de Données")"
        label_db_name="$(gt "Nom de la Base de Données")"
        label_db_user="$(gt "Utilisateur de la Base de Données")"
        WIDTH_REP=${#label_rep}
        WIDTH_DB_HOST=${#label_db_host}
        WIDTH_DB_NAME=${#label_db_name}
        WIDTH_DB_USER=${#label_db_user}
        for label_width in "$WIDTH_REP" "$WIDTH_DB_HOST" "$WIDTH_DB_NAME" "$WIDTH_DB_USER"; do
            (( label_width > WIDTH )) && WIDTH=$label_width
        done
        WIDTH=$((WIDTH + 6))
        local _def_rep="${REP_GLPI:-/var/www/html/glpi}" _def_db_host="${DB_HOST:-localhost}" _def_db="${DB_NAME:-glpi}" _def_user="${DB_USER:-glpi_user}"
        while true; do
            form=$(dialog --clear --backtitle "$(gt "Installation de GLPI")" --title "$(gt "Choix pour l'installation de GLPI")" \
                --form "$(gt "Paramètres pour GLPI") ${VERSION_SELECT} $(gt "Modifiez et confirmez les valeurs ci-dessous")" 18 68 8 \
                "📁 $(gt "Répertoire d'installation")"         1 2 "${_def_rep}"     1 ${WIDTH} 20 40 \
                "🖥️ $(gt "Hôte de la Base de Données")"        3 2 "${_def_db_host}" 3 ${WIDTH} 20 20 \
                "🗄️ $(gt "Nom de la Base de Données")"         5 2 "${_def_db}"      5 ${WIDTH} 20 20 \
                "👤 $(gt "Utilisateur de la Base de Données")" 7 2 "${_def_user}"    7 ${WIDTH} 20 20 \
                2>&1 >/dev/tty)
            rc=$?
            # Transformer les lignes du formulaire en variables
            IFS=$'\n' read -r rep_glpi db_host db_name db_user <<< "$form"
            rep_glpi="$(sanitize_path_value "$rep_glpi")"
            db_host="$(sanitize_path_value "$db_host")"
            db_name="$(sanitize_name_value "$db_name")"
            db_user="$(sanitize_name_value "$db_user")"
            [ -z "$rep_glpi" ] && rep_glpi="$_def_rep"
            [ -z "$db_host" ] && db_host="$_def_db_host"
            [ -z "$db_name" ] && db_name="$_def_db"
            [ -z "$db_user" ] && db_user="$_def_user"
            if [[ ! "$db_name" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]; then
                db_name="glpi_${db_name}"
            fi
            rep_glpi="${rep_glpi//\\//}"
            if [ -z "${rep_glpi}" ] || [[ "${rep_glpi}" != /* ]]; then
                rep_glpi="${_def_rep}"
            fi
            rep_glpi="$(printf '%s' "${rep_glpi}" | sed -E 's#/{2,}#/#g')"
            REP_GLPI="${rep_glpi%/}/"
            DB_HOST="$db_host"
            DB_NAME="$db_name"
            DB_USER="$db_user"
            # Si annulation ou ESC
            if [[ $rc -ne 0 ]]; then
                warn "$(gt "Arrêt de l'installation par l'utilisateur.")"
                form=$(dialog --clear --title "$(gt "Installation de GLPI")" --msgbox "$(gt "Sélection annulée par l'utilisateur.")" 7 60 2>&1 >/dev/tty)
                exit 1
            fi
            # --- VALIDATIONS ---
            # Répertoire d’installation
            if ! validate_glpi_path "$REP_GLPI"; then
                continue
            fi
            # Hôte de la base de données
            if ! validate_db_host "$DB_HOST"; then
                continue
            fi
            # Nom de la base de données
            if ! validate_db_name "$DB_NAME"; then
                continue
            fi
            # Utilisateur de la base de données
            if ! validate_db_user "$DB_USER"; then
                continue
            fi
            # Si tout est valide
            break
        done
        # Assignation des valeurs finales
        local DOWNLOADLINK="https://github.com/glpi-project/glpi/releases/download/${VERSION_SELECT}/glpi-${VERSION_SELECT}.tgz"
        export DOWNLOADLINK DB_HOST REP_GLPI DB_NAME DB_USER INVOKING_HOME TIMEZONE VERSION_SELECT
        # Lancement de l’installation
        run_sequence "install"
    elif [[ "${SELECTED_MENU}" == 2 ]]; then # Mise à jour de GLPI
        info "$(gt "Options de mise à jour de GLPI")"
        check_glpi_installed
        # Si au moins un répertoire GLPI trouvé, demander à l'utilisateur de choisir
        if [[ "${#glpi_dirs[@]}" -gt 0 ]]; then
            # Préparer les arguments pour dialog
            find_rep=()
            rep_map=()
            number=1
            first="ON"
            # Correction : boucle while → for (syntaxe correcte)
            for dir in "${glpi_dirs[@]}"; do
                find_rep+=("${number}" "${dir}" "${first}")
                rep_map+=("${dir}")
                first="OFF"
                ((number++))
            done
            # Menu de sélection d’installation GLPI
            FIND_REP_GLPI=$(dialog \
                --backtitle "$(gt "Mise à jour de GLPI")" \
                --title "$(gt "Sélection du répertoire d'installation")" \
                --radiolist "$(gt "Veuillez sélectionner le répertoire d'installation de GLPI :")" 20 70 8 \
                "${find_rep[@]}"  2>&1 >/dev/tty)
            rc=$?
            # Convertir le numéro choisi en index du tableau (0-based)
            local index=""
            index=$((FIND_REP_GLPI - 1))
            # Récupérer le vrai chemin correspondant
            REP_GLPI="${rep_map[$index]}"
            if [[ $rc -ne 0 ]]; then
                warn "$(gt "Sélection annulée par l'utilisateur.")" | tee -a "${DEBUGFILE}"
                form=$(dialog --clear --title "$(gt "Annulation")" --msgbox "$(gt "Installation annulée par l'utilisateur.")" 7 50 2>&1 >/dev/tty)
                return 1
            fi
            GLPI_CLI_VERSION="$(get_installed_glpi_version "${REP_GLPI}")"
            mapfile -t newer_tags < <(get_newer_glpi_tags "${GLPI_CLI_VERSION}")
            mapfile -t find_version < <(build_version_choices "${newer_tags[@]}")
            if ! VERSION_SELECT="$(select_glpi_update_version "${find_version[@]}")"; then
                warn "$(gt "Sélection annulée par l'utilisateur.")"
                return 1
            fi
            dialog --clear --title "${MSG_INFO}" --msgbox "$(gt "Version installée :") ${VERSION_SELECT} $(gt ", dans le répertoire :") ${REP_GLPI}" 10 100 >/dev/tty 2>&1
            export DOWNLOADLINK="https://github.com/glpi-project/glpi/releases/download/${VERSION_SELECT}/glpi-${VERSION_SELECT}.tgz"
            export VERSION_SELECT REP_GLPI DOWNLOADLINK REP_BACKUP_COMPRESS INVOKING_HOME GLPI_CLI_VERSION
            # Lancement de la mise à jour
            run_sequence "update"
        fi
    elif [[ "${SELECTED_MENU}" == 3 ]]; then # Sauvegarde complète de GLPI
        info "$(gt "Options de sauvegarde de GLPI")"
        check_glpi_installed
        # Si au moins un répertoire GLPI trouvé, demander à l'utilisateur de choisir
        if [[ "${#glpi_dirs[@]}" -gt 0 ]]; then
            # Préparer les arguments pour dialog
            find_rep=()
            rep_map=()
            number=1
            first="ON"
            for dir in "${glpi_dirs[@]}"; do
                find_rep+=("${number}" "${dir}" "${first}")
                rep_map+=("${dir}")
                first="OFF"
                ((number++))
            done
            # Sélecteur de répertoire GLPI pour sauvegarde
            FIND_REP_GLPI=$(dialog \
                --backtitle "$(gt "Sauvegarde complète de GLPI")" \
                --title "$(gt "Sélection du répertoire de sauvegarde")" \
                --radiolist "$(gt "Veuillez sélectionner le répertoire de sauvegarde de GLPI :")" 20 70 8 \
                "${find_rep[@]}" 2>&1 >/dev/tty)
            rc=$?
            if [[ $rc -ne 0 ]]; then
                warn "$(gt "Sélection annulée par l'utilisateur.")"
                dialog --clear --title "$(gt "Annulation")" --msgbox "$(gt "Sélection annulée par l'utilisateur.")" 7 50 >/dev/tty 2>&1
                return 1
            fi
            REP_GLPI="${rep_map[$((FIND_REP_GLPI - 1))]}"
            export REP_GLPI INVOKING_HOME REP_BACKUP_COMPRESS
            # Lancement de la sauvegarde
            run_sequence "backup"
        fi
    elif [[ "${SELECTED_MENU}" == 4 ]]; then # Restauration de GLPI
        info "$(gt "Options de restauration de GLPI")"
        # Recherche dans le répertoire de sauvegardes
        check_backups_existed
        if [[ "${BACKUP_FOUND}" == true ]]; then
            prompt_restore_options
        fi
    elif [[ "${SELECTED_MENU}" == 5 ]]; then # Migration de GLPI
        info "$(gt "Options de migration de GLPI")"
        # Recherche dans le répertoire de sauvegardes
        check_backups_existed
        # Si au moins un fichier de sauvegarde trouvé, demander à l'utilisateur de choisir
        if [[ "${#backup_files[@]}" -gt 0 ]]; then
            # Préparer les arguments pour dialog
            find_bck=()
            rep_map=()
            number=1
            first="ON"
            for dir in "${backup_files[@]}"; do
                find_bck+=("${number}" "${dir}" "${first}")
                rep_map+=("${dir}")
                first="OFF"
                ((number++))
            done
            # Sélecteur de répertoire GLPI pour migration
            FIND_REP_GLPI=$(dialog \
                --backtitle "$(gt "Options de migration de GLPI")" \
                --title "$(gt "Sélection du répertoire de migration")" \
                --radiolist "$(gt "Veuillez sélectionner le répertoire de migration de GLPI :")" 20 70 8 \
                "${find_bck[@]}" 2>&1 >/dev/tty)
            rc=$?
            # Convertir le numéro choisi en index du tableau (0-based)
            local index=""
            index=$((FIND_REP_GLPI - 1))
            # Récupérer le vrai chemin correspondant
            REP_GLPI="${rep_map[$index]}"
            if [[ $rc -ne 0 ]]; then
                warn "Sélection annulée par l'utilisateur."
                form=$(dialog --title "Annulation" --msgbox "Sélection annulée par l'utilisateur." 7 50 2>&1 >/dev/tty)
                return 1
            fi
            export REP_GLPI INVOKING_HOME REP_BACKUP_COMPRESS
            # Lancement de la restauration
            run_sequence "restore"      
        fi
    fi
    debug_end
}
# Valide le répertoire d’installation de GLPI
function validate_glpi_path() {
    debug_start    
    local path="$1"
    local clean_path
    # Nettoyage
    clean_path="$(printf '%s' "$path" | tr -d '\r\n' | sed -E 's#/{2,}#/#g' \
        | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
    # Vérification du format
    if ! [[ "$clean_path" =~ ^(/var/www|/srv|/opt|/usr/share)/[^[:space:]]*glpi[^[:space:]]*$ ]]; then
        dialog --clear --title "$(gt "Validation du répertoire d’installation de GLPI")" --msgbox "$(gt "Répertoire d’installation invalide :") ${clean_path}\n\n$(gt "Doit commencer par /var/www/, /srv/, /opt/ ou /usr/share/\net contenir 'glpi' dans le nom d’un dossier.")" 12 70
        warn "$(gt "Validation échouée : répertoire d’installation invalide :") (${clean_path})"
        return 1
    fi
    debug_end
}
# Valide le répertoire d’installation de GLPI
function validate_db_host() {
    debug_start    
    host=$1
    # Nettoyage de base
    clean_host=$(printf '%s' "$host" | tr -d '\r' | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')
    # Cas simples
    case "$clean_host" in
        localhost|::1|\[::1\])
            return 0 ;;
    esac
    # Vérif IPv4 (structure correcte)
    if printf '%s\n' "${clean_host}" | grep -Eq '^([0-9]{1,3}\.){3}[0-9]{1,3}$'; then
        IFS=.
        set -- "${clean_host}"
        for o in "$@"; do
            case $o in
                *[!0-9]*) dbhost_err "${clean_host}"; return 1 ;;
            esac
            [ "$o" -ge 0 ] 2>/dev/null && [ "$o" -le 255 ] 2>/dev/null || {
                dbhost_err "${clean_host}"; return 1;
            }
        done
        return 0
    fi
    # Vérif nom de domaine (FQDN simple)
    if printf '%s\n' "${clean_host}" | grep -Eq '^([A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?\.)+[A-Za-z]{2,}$'; then
        return 0
    fi
    # Sinon invalide
    dbhost_err "${clean_host}"
    debug_end
}
