        fi
        if dnf install -y crontabs logrotate cronie tar nginx mariadb-server mariadb perl curl jq php epel-release; then
            info "$(gt "Installation des paquets et services LAMP terminée avec succès.")"
        else
            warn "$(gt "Échec de l'installation des paquets et services LAMP.")"
