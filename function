        fi
        sed -i 's/^\(;\?\)\(user =\).*/\2 nginx/' /etc/php-fpm.d/www.conf
        sed -i 's/^\(;\?\)\(group =\).*/\2 nginx/' /etc/php-fpm.d/www.conf
        if systemctl enable --now mariadb nginx php-fpm; then
            info "$(gt "Activation et démarrage des services MariaDB, NGINX et PHP-FPM terminés avec succès.")"
        else
            warn "$(gt "Échec de l'activation et du démarrage des services MariaDB, NGINX et PHP-FPM.")"
            return 1
        fi
        if firewall-cmd --permanent --zone=public --add-service=http && firewall-cmd --reload; then
            info "$(gt "Configuration du pare-feu pour HTTP terminée avec succès.")"
        else
            warn "$(gt "Échec de la configuration du pare-feu pour HTTP.")"
            return 1
        fi
    fi
    info "$(gt "Fin de l'installation des paquets nécessaires...")"
    debug_end
}
function manage_service() {
    debug_start
    local service="$1"
    local label="$2"
    info "$(gt "Activation et démarrage du service :") ${label}..."
    # Activer et redémarrer le service avec journalisation
    {
        systemctl enable "${service}"
        systemctl restart "${service}"
    } || {
        error "$(gt "Échec lors de la gestion du service :") ${label}."
        return 1
    }
    # Vérifier l'état du service
    if systemctl is-active --quiet "${service}"; then
        info "$(gt "Service géré avec succès :") ${label}."
    else
        warn "$(gt "Le service n'est pas actif — démarrage forcé..")"
        # Forcer le redémarrage une seconde fois
        {
            systemctl restart "${service}"
        } || {
            error "$(gt "Échec du démarrage du service :") ${label}."
            return 1
        }
        # Vérifier à nouveau l'état du service
        if systemctl is-active --quiet "${service}"; then
            info "$(gt "Service démarré avec succès :") ${label}."
        else
            error "$(gt "Le service est toujours inactif après tentative de démarrage :") ${label}."
            return 1
        fi
    fi
    debug_end
}
# Détection du fuseau horaire système
function get_timezone() {
    debug_start
    info "$(gt "Détection du fuseau horaire...")"
    # Si TIMEZONES n’est pas encore défini
    if [ -z "${TIMEZONES:-}" ]; then
        local tzfile=""
        if command -v timedatectl >/dev/null 2>&1; then # timedatectl (méthode la plus fiable)
            TIMEZONES=$(timedatectl show -p Timezone --value 2>/dev/null || true)
        fi
        if [ -z "${TIMEZONES:-}" ] && [ -f /etc/timezone ]; then # Fichier /etc/timezone (Debian/Ubuntu)
            TIMEZONES=$(head -n 1 /etc/timezone 2>/dev/null || true)
        fi
        if [ -z "${TIMEZONES:-}" ]; then # Lien symbolique /etc/localtime (méthode universelle)
            if [ -L /etc/localtime ] || [ -f /etc/localtime ]; then
                tzfile=$(readlink -f /etc/localtime 2>/dev/null || true)
                if [[ "$tzfile" == *"/usr/share/zoneinfo/"* ]]; then
                    TIMEZONES="${tzfile#*/usr/share/zoneinfo/}"
                fi
            fi
        fi
        if [ -z "${TIMEZONES:-}" ] && [ -f /etc/sysconfig/clock ]; then # /etc/sysconfig/clock (RHEL / CentOS)
            TIMEZONES=$(awk -F= '/^ZONE/ {gsub(/"/,"",$2); print $2}' /etc/sysconfig/clock 2>/dev/null || true)
        fi
        if [ -z "${TIMEZONES:-}" ]; then # Par défaut si rien trouvé
            TIMEZONES="UTC"
        fi
        TIMEZONES="$(echo "${TIMEZONES}" | xargs)"
        export TIMEZONES
        info "$(gt "Fuseau horaire détecté :") ${TIMEZONES}"
    else
        info "$(gt "Fuseau horaire déjà défini :") ${TIMEZONES}"
    fi
    debug_end
}
sql_escape_string() {
    local value="$1"
    value="${value//\\/\\\\}"
    value="${value//\'/\'\'}"
    printf '%s' "$value"
}
sql_escape_identifier() {
    local value="$1"
    value="${value//\`/\`\`}"
    printf '%s' "$value"
}
mysql_root_exec() {
    local sql="$1"
    if [ -n "${SQLROOTPWD:-}" ]; then
        if sudo "${MYSQL_CMD}" -u root -p"${SQLROOTPWD}" --batch --silent 1>>"${DEBUGFILE}" 2>>"${ERRORFILE}" <<< "${sql}"; then
            return 0
        fi
    fi
    sudo "${MYSQL_CMD}" -u root --batch --silent 1>>"${DEBUGFILE}" 2>>"${ERRORFILE}" <<< "${sql}"
}
mysql_root_query() {
    local sql="$1"
    if [ -n "${SQLROOTPWD:-}" ]; then
        if sudo "${MYSQL_CMD}" -u root -p"${SQLROOTPWD}" --batch --skip-column-names --silent 2>>"${ERRORFILE}" <<< "${sql}"; then
            return 0
        fi
    fi
    sudo "${MYSQL_CMD}" -u root --batch --skip-column-names --silent 2>>"${ERRORFILE}" <<< "${sql}"
}
get_tzinfo_cmd() {
    if command -v mysql_tzinfo_to_sql >/dev/null 2>&1; then
        printf '%s\n' "mysql_tzinfo_to_sql"
        return 0
    fi
    if command -v mariadb-tzinfo-to-sql >/dev/null 2>&1; then
        printf '%s\n' "mariadb-tzinfo-to-sql"
        return 0
    fi
    return 1
}
# Configuration de la base de données MariaDB
function mariadb_configure() {
    debug_start
    trap 'on_error' ERR
    info "$(gt "Configuration de la base de données")"
    # --- Détection de la commande MySQL/MariaDB ---
    if MYSQL_CMD="$(command -v mariadb 2>/dev/null)"; then
        :
    elif MYSQL_CMD="$(command -v mysql 2>/dev/null)"; then
        :
    else
        warn "$(gt "Commande MySQL/MariaDB introuvable.")"
        return 1
    fi
    # --- Détermination du fuseau horaire ---
    get_timezone
    TIMEZONES="${TIMEZONES:-Europe/Paris}"
    local db_name_sql db_user_sql sql_root_pwd_sql sql_glpi_pwd_sql timezone_sql
    db_name_sql="$(sql_escape_identifier "${DB_NAME}")"
    db_user_sql="$(sql_escape_string "${DB_USER}")"
    sql_root_pwd_sql="$(sql_escape_string "${SQLROOTPWD}")"
    sql_glpi_pwd_sql="$(sql_escape_string "${SQLGLPIPWD}")"
    timezone_sql="$(sql_escape_string "${TIMEZONES}")"
    info "Utilisation de la commande : ${MYSQL_CMD}"
    info "Connexion à l'hôte : ${DB_HOST:-localhost}"
    info "Mot de passe root : ${sql_root_pwd_sql}"
    info "Création base : ${DB_NAME}"
    info "Utilisateur : ${DB_USER}"
    info "Mdp utilisateur : ${sql_glpi_pwd_sql}"
    info "Timezone : ${TIMEZONES}"
    # --- Script SQL principal ---
    local _sql_root
    _sql_root=$(cat <<SQL
ALTER USER 'root'@'localhost' IDENTIFIED BY '${sql_root_pwd_sql}';
DELETE FROM mysql.user WHERE User = '';
DELETE FROM mysql.user WHERE User = 'root' AND Host != 'localhost';
DROP DATABASE IF EXISTS test;
DELETE FROM mysql.db WHERE Db = 'test' OR Db LIKE 'test\\_%';
GRANT ALL PRIVILEGES ON *.* TO 'root'@'localhost' WITH GRANT OPTION;
FLUSH PRIVILEGES;
CREATE DATABASE IF NOT EXISTS \`${db_name_sql}\`
    CHARACTER SET utf8mb4
    COLLATE utf8mb4_unicode_ci;
CREATE USER IF NOT EXISTS '${db_user_sql}'@'localhost'
    IDENTIFIED BY '${sql_glpi_pwd_sql}';
ALTER USER '${db_user_sql}'@'localhost'
    IDENTIFIED BY '${sql_glpi_pwd_sql}';
GRANT ALL PRIVILEGES ON \`${db_name_sql}\`.* TO '${db_user_sql}'@'localhost';
GRANT SELECT ON mysql.time_zone_name TO '${db_user_sql}'@'localhost';
GRANT SELECT ON mysql.time_zone TO '${db_user_sql}'@'localhost';
FLUSH PRIVILEGES;
SQL
    )
    # --- Application du script SQL ---
    if mysql_root_exec "${_sql_root}"; then
        info "$(gt "Configuration de la base de données terminée avec succès.")"
    else
        warn "$(gt "Erreur SQL lors de l'installation.")"
        return 1
    fi
    # --- Vérification de la création de base ---
    if ! mysql_root_exec "USE \`${db_name_sql}\`;"; then
        warn "$(gt "Impossible d'accéder à la base :") ${DB_NAME}"
        return 1
    fi
    # --- Vérification des tables timezone ---
    local TIMEZONE_TABLE_COUNT
    TIMEZONE_TABLE_COUNT="$(
        mysql_root_query "SELECT COUNT(*) FROM mysql.time_zone_name WHERE Name = '${timezone_sql}';" || true
    )"
    if [[ -z "${TIMEZONE_TABLE_COUNT}" || "${TIMEZONE_TABLE_COUNT}" -eq 0 ]]; then
        info "$(gt "Configuration de l'import des fuseaux horaires dans MariaDB")"
        local TZINFO_CMD
        if ! TZINFO_CMD="$(get_tzinfo_cmd)"; then
            warn "$(gt "Commande mysql_tzinfo_to_sql/mariadb-tzinfo-to-sql introuvable, impossible d'importer les fuseaux horaires.")"
            warn "$(gt "Installe le paquet mariadb-client-compat, mariadb-client ou mysql-client selon ta distribution.")"
            return 1
        fi
        local rc=1
        if [ -n "${SQLROOTPWD:-}" ] && \
            sudo "${TZINFO_CMD}" /usr/share/zoneinfo 2>>"${ERRORFILE}" \
            | sudo "${MYSQL_CMD}" -u root -p"${SQLROOTPWD}" mysql 1>>"${DEBUGFILE}" 2>>"${ERRORFILE}"; then
            rc=0
        elif sudo "${TZINFO_CMD}" /usr/share/zoneinfo 2>>"${ERRORFILE}" \
            | sudo "${MYSQL_CMD}" -u root mysql 1>>"${DEBUGFILE}" 2>>"${ERRORFILE}"; then
            rc=0
        else
            rc=$?
        fi
        debug "$(gt "Code retour de l'import des timezones :") ${rc}"
        if [[ "${rc}" -eq 0 ]]; then
            info "$(gt "Importation des fuseaux horaires terminée avec succès.")"
        else
            warn "$(gt "Erreur: import du timezone échoué.")"
            return 1
        fi
        # --- Paramétrage du fuseau horaire ---
        local _sql_tz
        _sql_tz=$(cat <<SQL
SET GLOBAL time_zone = '${timezone_sql}';
SET time_zone = '${timezone_sql}';
GRANT SELECT ON mysql.time_zone_transition TO '${db_user_sql}'@'localhost';
GRANT SELECT ON mysql.time_zone_transition_type TO '${db_user_sql}'@'localhost';
FLUSH PRIVILEGES;
SQL
        )
        if mysql_root_exec "${_sql_tz}"; then
            info "$(gt "Configuration du fuseau horaire dans MariaDB terminée avec succès.")"
        else
            warn "$(gt "Erreur lors de la configuration du fuseau horaire dans MariaDB.")"
            return 1
        fi
    else
        info "$(gt "Les tables de fuseaux horaires existent déjà dans MariaDB, pas d'import nécessaire.")"
    fi
    # --- Redémarrage du service ---
    if systemctl is-active --quiet mariadb; then
        info "$(gt "Redémarrage du service MariaDB...")"
        manage_service "mariadb" "MariaDB" || return 1
    elif systemctl is-active --quiet mysql; then
        info "$(gt "Redémarrage du service MySQL...")"
        manage_service "mysql" "MySQL" || return 1
    fi
    debug_end
}   
# Téléchargement et décompression de GLPI
function download_untar_glpi(){
    debug_start    
    trap 'on_error' ERR
    set -Euo pipefail
    info "$(gt "Téléchargement et extraction de GLPI") ${VERSION_SELECT} $(gt "dans le répertoire") ${REP_GLPI}"
    "${REP_GLPI}"
    if [[ -z "${DOWNLOADLINK:-}" ]]; then
        warn "$(gt "Lien de téléchargement de GLPI non défini.")"
        return 1
    fi
    # Téléchargement de GLPI
    tmp_file="$(mktemp /tmp/glpi_XXX.tar.gz)"
    info "$(gt "Téléchargement") ${DOWNLOADLINK} $(gt "dans le répertoire") ${tmp_file}"
    if wget -q -O "$tmp_file" "${DOWNLOADLINK}" >> "${DEBUGFILE}" 2>> "${ERRORFILE}"; then
        info "$(gt "Téléchargement de GLPI terminés avec succès.")"
    else
        warn "$(gt "Échec du téléchargement de GLPI.")"
        rm -f "$tmp_file"
        return 1
    fi
    # Vérification de l'intégrité du fichier téléchargé
    info "$(gt "Vérification de l'intégrité du fichier téléchargé...")"
    EXPECTED_HASH=$(curl -s -H "User-Agent: glpi-installer" "${API_URL_SHA256}/${VERSION_SELECT}" \
    | grep '"digest":' \
    | sed -E 's/.*"sha256:([0-9a-f]+)".*/\1/' \
    | head -n 1)
    if ! [[ -n "$EXPECTED_HASH" ]]; then
        EXPECTED_HASH="poc"
    fi
    ACTUAL_HASH=$(sha256sum "$tmp_file" | awk '{print $1}')
    if [[ -n "$EXPECTED_HASH" ]]; then
        if ! [[ "$EXPECTED_HASH" != "$ACTUAL_HASH" ]]; then
            info "✔️ $(gt "Vérification de l'intégrité réussie.")"
        else
            info "$(gt "Échec de la vérification de l'intégrité du fichier téléchargé.")"
        fi
    fi
    # Création du répertoire d'installation si nécessaire
    if mkdir -p "$REP_GLPI"; then
        info "$(gt "Répertoire d'installation de GLPI créé :") ${REP_GLPI}"
    else
        warn "$(gt "Échec de la création du répertoire d'installation de GLPI.")"
        rm -f "$tmp_file"
        return 1
    fi
    # Extraction de l’archive GLPI
    if tar -xzf "$tmp_file" -C "$REP_GLPI" --strip-components=1; then
        info "$(gt "Extraction de GLPI terminée avec succès.")"
        rm -f "$tmp_file"
    else
        warn "$(gt "Échec de l'extraction de GLPI.")"
        rm -f "$tmp_file"
        return 1
    fi
    sync # S'assurer que toutes les écritures sont terminées
    debug_end
}
# Mise en place des réglage pour GLPI
function setup_glpi(){
    debug_start
    trap 'on_error' ERR
    set -Euo pipefail
    info "$(gt "Mise en place des réglages pour GLPI...")"
    source_os_release
    local CMD=(
    php "${REP_GLPI}bin/console" db:install
    --db-host "${DB_HOST}"
    --db-port=3306
    --db-name="${DB_NAME}"
    --db-user="${DB_USER}"
    --db-password="${SQLGLPIPWD}"
    --default-language="${LANGUAGE}"
    --force
    --no-telemetry
    --quiet
    --no-interaction
    )
    info "Hôte de la base de données : ${DB_HOST}"
    info "Nom de la base de données : ${DB_NAME}"
    info "Utilisateur de la base de données : ${DB_USER}"
    info "MDP : ${SQLGLPIPWD}"
    # Définition des fichiers
    FILE_APACHE_CONF="/etc/apache2/sites-available/${DB_NAME}.conf"
    info "$(gt "Création du répertoire des logs.")"
    declare -A GLPI_DIRS=(
    [LOGS]="/var/log/${DB_NAME}"
    [CONFIG]="/etc/${DB_NAME}/config"
    [FILES]="/var/lib/${DB_NAME}/files"
    )
    # Création des répertoires
    for key in "${!GLPI_DIRS[@]}"; do
        folder="${GLPI_DIRS[$key]}"
        msg_ok_var="$(gt "Création du répertoire") ${key}"
        msg_fail_var="$(gt "Échec de créer le répertoire") ${key}"
        if mkdir -p "$folder"; then
            info "${msg_ok_var}"
        else
            warn "${msg_fail_var}"
            return 1
        fi
    done
    # Déplacement des fichiers GLPI
    info "$(gt "Déplacement du répertoire des fichiers GLPI")"
    mkdir -p "${GLPI_DIRS[FILES]}" "${GLPI_DIRS[CONFIG]}" "${GLPI_DIRS[LOGS]}"
    if [ -d "${REP_GLPI}/files" ]; then
        shopt -s dotglob nullglob
        glpi_files=( "${REP_GLPI}/files/"* )
        if [ "${#glpi_files[@]}" -gt 0 ]; then
            if mv -f "${glpi_files[@]}" "${GLPI_DIRS[FILES]}/"; then
                info "$(gt "Répertoire des fichiers GLPI déplacé avec succès.")"
            else
                warn "$(gt "Échec du déplacement du répertoire des fichiers GLPI.")"
                shopt -u dotglob nullglob
                return 1
            fi
        else
            info "$(gt "Aucun fichier GLPI à déplacer.")"
        fi
        shopt -u dotglob nullglob
    else
        warn "$(gt "Répertoire GLPI files introuvable :") ${REP_GLPI}/files"
        return 1
    fi
    # Création du fichier local_define.php
    info "$(gt "Création du fichier local_define.php")"
    if tee "${GLPI_DIRS[CONFIG]}/local_define.php" >/dev/null <<EOF
<?php
    define('GLPI_VAR_DIR', '${GLPI_DIRS[FILES]}');
    define('GLPI_LOG_DIR', '${GLPI_DIRS[LOGS]}');
EOF
    then
        info "$(gt "Fichier local_define.php créé avec succès.")"
    else
        warn "$(gt "Échec de la création du fichier local_define.php.")"
        return 1
    fi
    # Création du fichier downstream.php
    info "$(gt "Création du fichier downstream.php")"

    if tee "${REP_GLPI}/inc/downstream.php" >/dev/null <<EOF
<?php
    define('GLPI_CONFIG_DIR', '${GLPI_DIRS[CONFIG]}');
    if (file_exists(GLPI_CONFIG_DIR . '/local_define.php')) {
        require_once GLPI_CONFIG_DIR . '/local_define.php';
    }
EOF
    then
        info "$(gt "Fichier downstream.php créé avec succès.")"
    else
        warn "$(gt "Échec de la création du fichier downstream.php.")"
        return 1
    fi
    # Change permissions
    info "$(gt "Modification des permissions de") ${REP_GLPI}"
    if rights_glpi "${REP_GLPI}"; then
        info "$(gt "Permissions de") ${REP_GLPI} $(gt "modifiées avec succès.")"
    else
        warn "$(gt "Échec de la modification des permissions de") ${REP_GLPI}"
        return 1
    fi
    sync # S'assurer que toutes les écritures sont terminées
    info "$(gt "Configuration du serveur WEB pour GLPI :") ${REP_GLPI}"
    if check_install_user "${REP_GLPI}"; then
        info "$(gt "Utilisateur WEB détecté :") ${WEB_USER}"
        if [[ "${WEB_USER}" == "www-data" ]]; then
            network_info
            info "$(gt "Configuration pour Apache avec utilisateur :") ${WEB_USER}" # Pour le débogage
            # Configuration d'Apache pour GLPI
            info "$(gt "Configuration Virtual host d'Apache pour GLPI")"
            if tee "${FILE_APACHE_CONF}" <<EOF > /dev/null
<VirtualHost *:80>
    ServerName ${IPADRESS}
    DocumentRoot ${REP_GLPI}public
    <Directory ${REP_GLPI}public>
        Require all granted
        RewriteEngine On
        RewriteCond %{HTTP:Authorization} ^(.+)$
        RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
        RewriteCond %{REQUEST_FILENAME} !-f
        RewriteRule ^(.*)$ index.php [QSA,L]
    </Directory>
    ErrorLog /var/log/glpi/error.log
    CustomLog /var/log/glpi/access.log combined
</VirtualHost>
EOF
            then
                info "$(gt "Fichier de configuration Apache pour GLPI créé avec succès.")"
            else
                warn "$(gt "Échec de la création du fichier de configuration Apache pour GLPI.")"
                return 1
            fi
