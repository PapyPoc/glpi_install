    OnCalendar=*-*-* 6:00
    RandomizedDelaySec=60m
    Persistent=true
EOF
        info "$(gt "Fichier override.conf pour dnf-automatic créé avec succès.")"
        if systemctl enable --now dnf-automatic.timer; then
            info "$(gt "Activation de dnf-automatic.timer terminée avec succès.")"
