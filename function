    debug_end
}
# Fonction pour générer un hash de mot de passe compatible avec PHP
function php_password_hash() {
    debug_start
    local password="$1"
    if ! command -v php >/dev/null 2>&1; then
        warn "$(gt "PHP est introuvable, impossible de générer le hash du mot de passe.")"
        return 1
    fi
    # shellcheck disable=SC2016
    printf '%s' "${password}" | php -r '
$password = stream_get_contents(STDIN);
$hash = password_hash($password, PASSWORD_DEFAULT);
if ($hash === false) {
    exit(1);
}
echo $hash, PHP_EOL;
'
    debug_end
}
# Mise à jour des mot de passe des utilisateurs de GLPI
function maj_user_glpi(){
    trap 'on_error' ERR
    debug_start
    info "$(gt "Mise à jour des mots de passe des utilisateurs GLPI")"
    network_info
    get_timezone
    local MYSQL_CMD
    if MYSQL_CMD="$(command -v mariadb 2>/dev/null)"; then
        :
    elif MYSQL_CMD="$(command -v mysql 2>/dev/null)"; then
        :
    else
        warn "$(gt "Commande MySQL/MariaDB introuvable.")"
        return 1
    fi
    # --- Vérification des variables critiques ---
    if [ -z "${DB_NAME:-}" ] || [ -z "${DB_USER:-}" ] || [ -z "${SQLGLPIPWD:-}" ] || [ -z "${IPADRESS:-}" ]; then
        warn "$(gt "Variables manquantes : DB_NAME, DB_USER, SQLGLPIPWD, IPADRESS")"
        return 1
    fi
    if [ -z "${ADMINGLPIPWD:-}" ] || [ -z "${POSTGLPIPWD:-}" ] || [ -z "${TECHGLPIPWD:-}" ] || [ -z "${NORMGLPIPWD:-}" ]; then
        warn "$(gt "Un ou plusieurs mots de passe GLPI ne sont pas définis")"
        return 1
    fi
    local glpi_timezone glpi_language url_base
    glpi_timezone="${TIMEZONE:-${TIMEZONES:-Europe/Paris}}"
    glpi_language="${GLPI_LANGUAGE:-${LANGUAGE:-fr_FR}}"
    url_base="${URL_BASE:-${IPADRESS}}"
    # GLPI attend plutôt une URL complète
    if [[ "${url_base}" != http://* && "${url_base}" != https://* ]]; then
        url_base="http://${url_base}"
    fi
    # debug "Base de données : ${DB_NAME}"
    # debug "Utilisateur SQL : ${DB_USER}"
    # debug "Mot de passe SQL : ${SQLGLPIPWD}"
    # debug "Timezone GLPI : ${glpi_timezone}"
    # debug "Langue GLPI : ${glpi_language}"
    # debug "URL GLPI : ${url_base}"
    # debug "User GLPI : glpi ADMINGLPIPWD=${ADMINGLPIPWD}"
    # debug "User GLPI : post-only POSTGLPIPWD=${POSTGLPIPWD}"
    # debug "User GLPI : tech TECHGLPIPWD=${TECHGLPIPWD}"
    # debug "User GLPI : normal NORMGLPIPWD=${NORMGLPIPWD}"
    debug "Construction des hash PHP password_hash()..."
    local hash_admin hash_post hash_tech hash_normal hash_admin_sql hash_post_sql hash_tech_sql hash_normal_sql timezone_sql language_sql url_base_sql _sql_user
    hash_admin="$(php_password_hash "${ADMINGLPIPWD}")" || return 1
    hash_post="$(php_password_hash "${POSTGLPIPWD}")" || return 1
    hash_tech="$(php_password_hash "${TECHGLPIPWD}")" || return 1
    hash_normal="$(php_password_hash "${NORMGLPIPWD}")" || return 1
    hash_admin_sql="$(sql_escape_string "${hash_admin}")"
    hash_post_sql="$(sql_escape_string "${hash_post}")"
    hash_tech_sql="$(sql_escape_string "${hash_tech}")"
    hash_normal_sql="$(sql_escape_string "${hash_normal}")"
    timezone_sql="$(sql_escape_string "${glpi_timezone}")"
    language_sql="$(sql_escape_string "${glpi_language}")"
    url_base_sql="$(sql_escape_string "${url_base}")"
    _sql_user=$(cat <<SQL
UPDATE glpi_users SET password = '${hash_admin_sql}', is_active = 1 WHERE name = 'glpi';
UPDATE glpi_users SET password = '${hash_post_sql}', is_active = 1 WHERE name = 'post-only';
UPDATE glpi_users SET password = '${hash_tech_sql}', is_active = 1 WHERE name = 'tech';
UPDATE glpi_users SET password = '${hash_normal_sql}', is_active = 1 WHERE name = 'normal';
UPDATE glpi_configs SET value = '${timezone_sql}' WHERE context = 'core' AND name = 'timezone';
UPDATE glpi_configs SET value = '${language_sql}' WHERE context = 'core' AND name = 'language';
UPDATE glpi_configs SET value = '${url_base_sql}' WHERE context = 'core' AND name = 'url_base';
SQL
    )
    debug $_sql_user
    if ! MYSQL_PWD="${SQLGLPIPWD}" "${MYSQL_CMD}" \
        -u "${DB_USER}" \
        --database="${DB_NAME}" \
        --batch \
        --silent \
        >>"${DEBUGFILE}" 2>>"${ERRORFILE}" <<< "${_sql_user}"; then
        warn "$(gt "Échec de la mise à jour des mots de passe des utilisateurs GLPI.")"
        return 1
    fi
    info "$(gt "Mise à jour des mots de passe des utilisateurs GLPI réussie.")"
    debug_end
}
function rights_glpi(){
    debug_start    
    REP_GLPI="${1:-/var/www/html/glpi}"
    # Changer les droits des répertoires et fichiers
    info "$(gt "Modification des permissions de") ${REP_GLPI}"
    find "${REP_GLPI}" -type d -exec chmod 755 {} \; 1> >(tee -a "${DEBUGFILE}") 2> >(tee -a "${ERRORFILE}" >&2)
    find "${REP_GLPI}" -type f -exec chmod 644 {} \; 1> >(tee -a "${DEBUGFILE}") 2> >(tee -a "${ERRORFILE}" >&2)
    # Changer le propriétaire des répertoires
    if check_distro ; then
        sudo chown -Rc "${WEB_USER}":"${WEB_USER}" /etc/glpi /var/lib/glpi /var/log/glpi "${REP_GLPI}"
    fi
    # SELinux configuration
    if [[ "${WEB_USER}" == "nginx" ]]; then
        if command -v semanage; then
            setsebool -P httpd_can_network_connect on
            setsebool -P httpd_can_network_connect_db on
            setsebool -P httpd_can_sendmail on
            for p in "${REP_GLPI}" /etc/glpi /var/lib/glpi /var/log/glpi "${REP_GLPI}marketplace"; do
                semanage fcontext -a -t httpd_sys_rw_content_t "${p}(/.*)?"
            done
            restorecon -R "${REP_GLPI}" /etc/glpi /var/lib/glpi /var/log/glpi "${REP_GLPI}marketplace"
        else
            error "$(date '+%F %T'): WARN: semanage non disponible — SELinux non configuré"
        fi
    fi
    info " $(gt "Permissions de GLPI modifiées avec succès.")"
    debug_end
}
