               --msgbox "$(gt "Nom de base de données déjà utilisé :") ${existing_name}" 10 60
        warn "$(gt "Nom de base de données déjà utilisé :") ${existing_name}"
        debug_end
        return 1
    fi
    debug_end
    return 0
}
