    dialog --clear --title "$(gt "Validation de l'hôte de la base de données")" --msgbox "$(gt "Hôte de base de données invalide :") ${v}\n\n$(gt "Autorisé : localhost, ::1/[::1], nom de domaine complet ou adresse IPv4.")" 10 70
    warn "${MSG_VALIDATE_DB_HOST_FAILED} (${v})"
    debug_end
    return 0
}
# Valide le nom de la base de données
function validate_db_name() {
    debug_start
    local name="$1"
