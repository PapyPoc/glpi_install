    clean_name="$(printf '%s' "$name" | tr -d '\r\n' | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
    # Vérification du format du nom
    if [[ ! "$clean_name" =~ ^[A-Za-z_][A-Za-z0-9_]{0,63}$ ]]; then
        dialog --clear --title "$(gt "Validation du nom de la base de données")" \
               --msgbox "$(gt "Nom de base de données invalide :") ${clean_name}\n\n$(gt "Doit commencer par une lettre et ne contenir que des lettres, chiffres ou underscores (_).")" 12 70
        warn "$(gt "Nom de la base de données invalide :") (${clean_name})"
