function get_glpi_db_info() {
    debug_start
    set -euo pipefail    
    trap 'on_error' ERR
    info "$(gt "Récupération des informations de la base de données GLPI")"
    REP_GLPI="${1:-/var/www/html/glpi}"
    file_downstream="${REP_GLPI}/inc/downstream.php"
    #local GLPI_CONFIG_DIR file_conf_glpi _conf_tmp
    # Vérification du fichier principal
    if [[ ! -f "${file_downstream}" ]]; then
        error "$(gt "Fichier introuvable :") ${file_downstream}"
        return 1
    fi
    # Extraction du répertoire de configuration via PHP
    GLPI_CONFIG_DIR=$(php -r "require '${file_downstream}'; echo (defined('GLPI_CONFIG_DIR')?GLPI_CONFIG_DIR:'');")
    if [[ -z "${GLPI_CONFIG_DIR}" ]]; then
        error "$(gt "Impossible de déterminer GLPI_CONFIG_DIR")"
        return 1
    fi
    file_conf_glpi="${GLPI_CONFIG_DIR}/config_db.php"
    if [[ ! -f "${file_conf_glpi}" ]]; then
        error "$(gt "Fichier introuvable :") ${file_conf_glpi}"
        return 1
    fi
    # Création d’un fichier temporaire nettoyé des CRLF
    _conf_tmp=$(mktemp)
    tr -d '\r' < "${file_conf_glpi}" > "${_conf_tmp}"
    # Extraction des valeurs (tolérante aux espaces)
    local DB_HOST DB_USER DB_PASSWORD DB_NAME GLPI_VERSION
    DB_HOST=$(sed -n "s/.*public[[:space:]]\+\$dbhost[[:space:]]*=[[:space:]]*'\([^']*\)'.*/\1/p" "${_conf_tmp}")
    DB_USER=$(sed -n "s/.*public[[:space:]]\+\$dbuser[[:space:]]*=[[:space:]]*'\([^']*\)'.*/\1/p" "${_conf_tmp}")
    DB_PASSWORD=$(sed -n "s/.*public[[:space:]]\+\$dbpassword[[:space:]]*=[[:space:]]*'\([^']*\)'.*/\1/p" "${_conf_tmp}")
    DB_NAME=$(sed -n "s/.*public[[:space:]]\+\$dbdefault[[:space:]]*=[[:space:]]*'\([^']*\)'.*/\1/p" "${_conf_tmp}")
    rm -f "${_conf_tmp}"
    # Détection de version GLPI
    GLPI_VERSION=$(php -r "require '${file_downstream}'; echo (defined('GLPI_VERSION')?GLPI_VERSION:'inconnue');")
    # Vérification des résultats
    if [[ -z "${DB_NAME}" || -z "${DB_USER}" ]]; then
        warn "$(gt "Impossible d’extraire les infos de base de données depuis") ${file_conf_glpi}"
        return 1
    fi
    # Affichage
    info "Informations GLPI détectées :"
    info "  Version GLPI : ${GLPI_VERSION}"
    info "  🖥️ Hôte DB      : ${DB_HOST}"
    info "  📦 Base DB      : ${DB_NAME}"
    info "  👤 Utilisateur  : ${DB_USER}"
    info "  🔒 Mot de passe : ${DB_PASSWORD}"
    info "$(gt "Impossible de récupérer les informations de la base de données GLPI.")"
    # Export des variables dans l’environnement appelant
    export GLPI_VERSION DB_HOST DB_NAME DB_USER DB_PASSWORD
}
# Sauvegarde de la base de donnée et des fichiers de GLPI
function backup_glpi() {
    debug_start    
    info "$(gt "Création de la sauvegarde")"
    # Récupération du nom de la base de données dans le fichier config de GLPI suivant le répertoire de GLPI
    info "$(gt "Lecture des variables de base de données de GLPI")"
    get_glpi_db_info "${REP_GLPI}"
    # Détermination de l’outil de dump
    local MYSQLDUMP_CMD
    MYSQLDUMP_CMD=$(command -v mysqldump 2>/dev/null || command -v mariadb-dump 2>/dev/null || echo mysqldump)
    # Répertoires de sauvegarde
    REP_BACKUP="${INVOKING_HOME}/backup_glpi_$(date +"%Y-%m-%d")"
    BDD_BACKUP="bdd_glpi_$(date +"%Y-%m-%d_%H-%M-%S").sql"
    if ! mkdir -p "${REP_BACKUP}"; then
        warn "$(gt "Échec de la création du répertoire de sauvegarde :") ${REP_BACKUP}"
        return 1
    fi
    # --- Export de la BDD ---
    info "$(gt "Exportation de la base de données.")"
    if ${MYSQLDUMP_CMD} -u "${DB_USER}" -p"${DB_PASSWORD}" --databases "${DB_NAME}" | \
        tee -a "${REP_BACKUP}/${BDD_BACKUP}" >>"${DEBUGFILE}" 2>>"${ERRORFILE}"; then
        if [[ -s "${REP_BACKUP}/${BDD_BACKUP}" ]]; then
            info "$(gt "Exportation de la base de données terminée avec succès.")"
        else
            warn "$(gt "Fichier de sauvegarde de la base de données vide :") ${REP_BACKUP}/${BDD_BACKUP}"
            return 1
        fi
    else
        error "$(gt "Échec de l'exportation de la base de données.")"
        return 1
    fi
    # --- Sauvegarde des fichiers ---
    info "$(gt "Sauvegarde des fichiers de GLPI")"
    for SRC in "/etc/glpi/config" "/var/lib/glpi/files" "${REP_GLPI}/plugins" "${REP_GLPI}/marketplace" "${REP_GLPI}/inc/downstream.php"; do
        if [ -e "${SRC}" ]; then
            info "$(gt "Copie de ${SRC} vers ${REP_BACKUP}/")"
            cp -Rf "${SRC}" "${REP_BACKUP}/"
        else
            warn "$(gt "Source manquante :") ${SRC}"
        fi
    done
    info "$(gt "Sauvegarde des fichiers terminée avec succès.")"
    # --- Compression ---
    info "$(gt "Compression de la sauvegarde")"
    mkdir -p "${REP_BACKUP_COMPRESS}"
    local BACKUP_FILE backup_label
    if [[ -n "${GLPI_CLI_VERSION:-}" && -n "${VERSION_SELECT:-}" ]]; then
        backup_label="${GLPI_CLI_VERSION}->${VERSION_SELECT}"
    else
        backup_label="${GLPI_VERSION:-${GLPI_CLI_VERSION:-unknown}}"
    fi
    BACKUP_FILE="${REP_BACKUP_COMPRESS}/glpi_$(date +"%Y-%m-%d")_${backup_label}.tar.gz"
    if tar -czf "${BACKUP_FILE}" -C "${REP_BACKUP}" . 2>> "${ERRORFILE}"; then
        info "$(gt "Compression terminée avec succès. Fichier créé :") (${BACKUP_FILE})"
        # Vérifier que le fichier compressé n'est pas vide
        if [ ! -s "${BACKUP_FILE}" ]; then
            warn "$(gt "Fichier de sauvegarde vide.") ${BACKUP_FILE}"
            return 1
        fi
    else
        warn "$(gt "Échec de la compression de la sauvegarde.")"
        return 1
    fi
    info "$(gt "Sauvegarde de GLPI terminée avec succès.")"
    sleep 2
    export REP_BACKUP REP_GLPI
    debug_end
}
